<!doctype html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --primary: {{ primary_color }};
    --ink: #111111;
    --ink-2: #333333;
    --paper: #FFFFFF;
    --paper-2: #FAFAFA;
    --mute: #999999;
    --rule: #ECECEC;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    width: 1536px; height: 1024px;
    font-family: 'Noto Sans JP', 'Inter', sans-serif;
    background: var(--paper);
    color: var(--ink);
    overflow: hidden;
    -webkit-font-smoothing: antialiased;
  }
  .slide {
    width: 1536px; height: 1024px;
    position: relative;
    padding: 80px 110px;
    border-top: 4px solid var(--primary);
  }
  /* Top header row */
  .header {
    display: flex; justify-content: space-between; align-items: center;
    padding-bottom: 30px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 50px;
  }
  .meta {
    display: flex; align-items: center; gap: 18px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px; letter-spacing: .14em; text-transform: uppercase;
    color: var(--mute);
  }
  .meta .cat {
    color: var(--primary); font-weight: 700;
    border-left: 3px solid var(--primary);
    padding-left: 14px;
  }
  .meta .sep { color: var(--rule); }
  .brand {
    font-family: 'Inter', sans-serif;
    font-weight: 700; font-size: 22px;
    letter-spacing: -.01em;
    display: flex; align-items: center;
    white-space: nowrap;
  }
  .brand .dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--primary);
    margin-right: 10px;
  }
  .brand .accent { color: var(--primary); font-weight: 800; }
  .brand .small { color: var(--mute); font-size: 18px; font-weight: 500; }

  /* Title block */
  .title-block { margin-bottom: 36px; }
  .title {
    font-family: 'Noto Sans JP', sans-serif;
    font-weight: 900;
    font-size: 66px;
    line-height: 1.15;
    color: var(--ink);
    letter-spacing: -.015em;
    max-height: 230px; overflow: hidden;
  }

  /* Lede */
  .lede {
    font-size: 22px;
    line-height: 1.7;
    color: var(--ink-2);
    margin-bottom: 60px;
    max-width: 1280px;
    max-height: 110px; overflow: hidden;
    font-weight: 400;
  }

  /* Key cards */
  .cards {
    display: grid;
    grid-template-columns: repeat({{ keypoints|length }}, 1fr);
    gap: 28px;
  }
  .card {
    padding: 28px 28px 30px;
    background: var(--paper-2);
    position: relative;
    border-top: 3px solid var(--primary);
    min-height: 190px;
  }
  .card .num {
    position: absolute; top: -3px; left: 0;
    width: 38px; height: 3px; background: var(--ink);
  }
  .card .ic {
    width: 44px; height: 44px;
    color: var(--primary);
    margin-bottom: 18px;
  }
  .card .ic svg { width: 100%; height: 100%; }
  .card .label {
    font-family: 'Noto Sans JP', sans-serif;
    font-weight: 700;
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink);
    letter-spacing: -.005em;
  }
  .card .idx {
    position: absolute; top: 18px; right: 22px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; font-weight: 700;
    color: var(--mute); letter-spacing: .08em;
  }

  /* Source badge */
  .source {
    position: absolute; bottom: 50px; right: 110px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px; font-weight: 600;
    color: var(--mute); letter-spacing: .1em;
    text-transform: uppercase;
  }
  .source b {
    color: var(--ink); margin-left: 6px; font-weight: 700;
  }
</style>
</head>
<body>
<div class="slide">

  <div class="header">
    <div class="meta">
      <span class="cat">{{ category }}</span>
      <span class="sep">/</span>
      <span>{{ today }}</span>
      <span class="sep">/</span>
      <span>MORNING EDITION</span>
    </div>
    <div class="brand"><span class="dot"></span>Now on&nbsp;<span class="accent">{{ brand_main }}</span><span class="small">{{ brand_sub }}</span></div>
  </div>

  <div class="title-block">
    <h1 class="title">{{ title }}</h1>
  </div>

  <p class="lede">{{ lede }}</p>

  <div class="cards">
    {% for kp in keypoints %}
    <div class="card">
      <div class="num"></div>
      <span class="idx">{{ '%02d' | format(loop.index) }}</span>
      <div class="ic">{{ icons[loop.index0]|safe }}</div>
      <div class="label">{{ kp }}</div>
    </div>
    {% endfor %}
  </div>

  <div class="source">SOURCE<b>{{ source }}</b></div>
</div>
</body>
</html>
